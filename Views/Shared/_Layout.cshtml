<!DOCTYPE html>
<html lang="id">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] — IMS Finance</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <script>
        tailwind.config = {
            theme: {
                extend: {
                    colors: {
                        primary: { DEFAULT: '#c0392b', dark: '#922b21', light: '#e74c3c' }
                    }
                }
            }
        }
    </script>
</head>
<body class="bg-gray-100 min-h-screen flex">

    <!-- Sidebar -->
    <aside class="w-64 min-h-screen bg-white shadow-lg flex flex-col fixed left-0 top-0 z-30">
        <!-- Logo -->
        <div class="bg-gradient-to-r from-red-700 to-red-500 px-6 py-5">
            <div class="text-white font-bold text-xl tracking-wide">IMS Finance</div>
            <div class="text-red-200 text-xs mt-1">Admin Panel</div>
        </div>

        <!-- Navigation -->
        <nav class="flex-1 px-4 py-6 space-y-1">
            <p class="text-xs font-semibold text-gray-400 uppercase tracking-wider mb-3 px-2">Menu</p>

            <a href="/Kontrak"
               class="flex items-center gap-3 px-3 py-2.5 rounded-lg text-sm font-medium transition-all
                      @(ViewData["ActiveMenu"]?.ToString() == "kontrak"
                        ? "bg-red-50 text-red-700 border-l-4 border-red-600"
                        : "text-gray-600 hover:bg-gray-50 hover:text-gray-900")">
                Input Kontrak Baru
            </a>

            <a href="/JatuhTempo"
               class="flex items-center gap-3 px-3 py-2.5 rounded-lg text-sm font-medium transition-all
                      @(ViewData["ActiveMenu"]?.ToString() == "jatuhtempo"
                        ? "bg-red-50 text-red-700 border-l-4 border-red-600"
                        : "text-gray-600 hover:bg-gray-50 hover:text-gray-900")">
                Cek Jatuh Tempo
            </a>

            <a href="/Denda"
               class="flex items-center gap-3 px-3 py-2.5 rounded-lg text-sm font-medium transition-all
                      @(ViewData["ActiveMenu"]?.ToString() == "denda"
                        ? "bg-red-50 text-red-700 border-l-4 border-red-600"
                        : "text-gray-600 hover:bg-gray-50 hover:text-gray-900")">
                Cek Denda
            </a>
        </nav>

        <!-- Footer -->
        <div class="px-4 py-4 border-t border-gray-100">
            <p class="text-xs text-gray-400 text-center">© 2024 PT. Inovasi Mitra Sejati</p>
        </div>
    </aside>

    <!-- Main Content -->
    <main class="flex-1 ml-64 p-8">
        @RenderBody()
    </main>

    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
