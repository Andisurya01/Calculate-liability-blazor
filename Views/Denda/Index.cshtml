@model DendaInputViewModel
@{
    ViewData["Title"]      = "Cek Denda Keterlambatan";
    ViewData["ActiveMenu"] = "denda";
}

<div class="max-w-3xl mx-auto">
    <div class="mb-6">
        <h1 class="text-2xl font-bold text-gray-800">Cek Denda Keterlambatan</h1>
        <p class="text-gray-500 text-sm mt-1">Hitung denda 0,1% per hari dari angsuran yang belum dibayarkan.</p>
    </div>

    <!-- Form Card -->
    <div class="bg-white rounded-xl shadow-sm border border-gray-100 p-6 mb-6">
        <div class="grid grid-cols-3 gap-4 mb-5">
            <div>
                <label class="block text-sm font-medium text-gray-700 mb-1">Nomor Kontrak</label>
                <input id="kontrakNo" type="text" placeholder="AGR00001"
                       class="w-full px-3 py-2 border border-gray-200 rounded-lg text-sm focus:outline-none focus:ring-2 focus:ring-red-300" />
            </div>
            <div>
                <label class="block text-sm font-medium text-gray-700 mb-1">Per Tanggal</label>
                <input id="perTanggal" type="date"
                       class="w-full px-3 py-2 border border-gray-200 rounded-lg text-sm focus:outline-none focus:ring-2 focus:ring-red-300" />
            </div>
            <div>
                <label class="block text-sm font-medium text-gray-700 mb-1">Sudah Bayar s/d Angsuran Ke-</label>
                <input id="sudahBayarKe" type="number" value="5" min="0"
                       class="w-full px-3 py-2 border border-gray-200 rounded-lg text-sm focus:outline-none focus:ring-2 focus:ring-red-300" />
            </div>
        </div>

        <!-- Sumber Toggle -->
        <div class="flex items-center gap-3 mb-5">
            <span class="text-sm text-gray-600 font-medium">Sumber data:</span>
            <div class="flex bg-gray-100 rounded-lg p-1">
                <button id="btnDB" onclick="setSumber('db')"
                        class="px-4 py-1.5 text-sm rounded-md font-medium transition-all bg-red-600 text-white">
                    Database
                </button>
                <button id="btnJson" onclick="setSumber('json')"
                        class="px-4 py-1.5 text-sm rounded-md font-medium transition-all text-gray-500 hover:text-gray-700">
                    JSON
                </button>
            </div>
        </div>

        <button onclick="cekDenda()"
                class="w-full py-2.5 bg-red-600 hover:bg-red-700 text-white font-medium rounded-lg transition-colors text-sm">
            🔍 Hitung Denda
        </button>
    </div>

    <!-- Loading -->
    <div id="loading" class="hidden text-center py-8">
        <div class="inline-block w-8 h-8 border-4 border-red-200 border-t-red-600 rounded-full animate-spin"></div>
        <p class="text-gray-500 text-sm mt-2">Menghitung denda...</p>
    </div>

    <!-- Error -->
    <div id="errorMsg" class="hidden bg-red-50 border border-red-200 text-red-700 rounded-lg px-4 py-3 text-sm mb-4"></div>

    <!-- Result -->
    <div id="result" class="hidden">
        <!-- Total Denda Summary -->
        <div class="bg-red-50 border border-red-200 rounded-xl p-5 mb-4 flex justify-between items-center">
            <div>
                <p class="text-sm text-red-600 font-medium">Total Keseluruhan Denda</p>
                <p id="resTotalDenda" class="text-3xl font-bold text-red-700"></p>
            </div>
            <div class="text-right">
                <p id="resInfo" class="text-sm text-red-500"></p>
                <p id="resSumber" class="text-xs text-red-400 mt-1"></p>
            </div>
        </div>

        <!-- Detail Table -->
        <div class="bg-white rounded-xl shadow-sm border border-gray-100 overflow-hidden">
            <div class="px-6 py-4 border-b border-gray-100">
                <h3 class="font-semibold text-gray-700 text-sm">Detail Denda Per Angsuran</h3>
            </div>
            <div class="overflow-x-auto">
                <table class="w-full text-sm">
                    <thead class="bg-gray-50">
                        <tr>
                            <th class="px-4 py-3 text-left text-xs font-semibold text-gray-500 uppercase">Kontrak No</th>
                            <th class="px-4 py-3 text-left text-xs font-semibold text-gray-500 uppercase">Client</th>
                            <th class="px-4 py-3 text-center text-xs font-semibold text-gray-500 uppercase">Angsuran Ke</th>
                            <th class="px-4 py-3 text-center text-xs font-semibold text-gray-500 uppercase">Hari Terlambat</th>
                            <th class="px-4 py-3 text-right text-xs font-semibold text-gray-500 uppercase">Total Denda</th>
                        </tr>
                    </thead>
                    <tbody id="detailTable"></tbody>
                    <tfoot id="totalRow" class="bg-gray-50 font-bold"></tfoot>
                </table>
            </div>
        </div>
    </div>
</div>

@section Scripts {
<script>
    let sumber = 'db';

    function setSumber(s) {
        sumber = s;
        document.getElementById('btnDB').className   = s === 'db'
            ? 'px-4 py-1.5 text-sm rounded-md font-medium transition-all bg-red-600 text-white'
            : 'px-4 py-1.5 text-sm rounded-md font-medium transition-all text-gray-500 hover:text-gray-700';
        document.getElementById('btnJson').className = s === 'json'
            ? 'px-4 py-1.5 text-sm rounded-md font-medium transition-all bg-red-600 text-white'
            : 'px-4 py-1.5 text-sm rounded-md font-medium transition-all text-gray-500 hover:text-gray-700';
    }

    async function cekDenda() {
        const kontrakNo   = document.getElementById('kontrakNo').value.trim();
        const perTanggal  = document.getElementById('perTanggal').value;
        const sudahBayarKe = parseInt(document.getElementById('sudahBayarKe').value);

        if (!kontrakNo || !perTanggal) {
            showError('Nomor kontrak dan tanggal wajib diisi.');
            return;
        }

        showLoading(true);
        hideResult();

        try {
            const res = await fetch('/Denda/GetResult', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({ kontrakNo, perTanggal, sudahBayarKe, sumber })
            });

            if (!res.ok) {
                const err = await res.json();
                showError(err.message);
                return;
            }

            const data = await res.json();
            renderResult(data);
        } catch (e) {
            showError('Gagal menghubungi server. Coba lagi.');
        } finally {
            showLoading(false);
        }
    }

    function renderResult(data) {
        const total = data.reduce((sum, d) => sum + d.totalDenda, 0);

        document.getElementById('resTotalDenda').textContent = 'Rp ' + formatNumber(total);
        document.getElementById('resInfo').textContent       = `${data.length} angsuran terlambat`;
        document.getElementById('resSumber').textContent     = 'Sumber: ' + (sumber === 'db' ? 'Database' : 'JSON');

        document.getElementById('detailTable').innerHTML = data.map(d => `
            <tr class="border-b border-gray-50 hover:bg-gray-50">
                <td class="px-4 py-3 text-gray-700 font-medium">${d.kontrakNo}</td>
                <td class="px-4 py-3 text-gray-600">${d.clientName}</td>
                <td class="px-4 py-3 text-center">
                    <span class="bg-red-100 text-red-700 text-xs font-semibold px-2 py-1 rounded-full">${d.angsuranKe}</span>
                </td>
                <td class="px-4 py-3 text-center">
                    <span class="bg-orange-100 text-orange-700 text-xs font-semibold px-2 py-1 rounded-full">${d.hariKeterlambatan} Hari</span>
                </td>
                <td class="px-4 py-3 text-right font-semibold text-red-600">Rp ${formatNumber(d.totalDenda)}</td>
            </tr>
        `).join('');

        document.getElementById('totalRow').innerHTML = `
            <tr>
                <td colspan="4" class="px-4 py-3 text-right text-sm text-gray-600">Total Denda:</td>
                <td class="px-4 py-3 text-right text-red-700 font-bold">Rp ${formatNumber(total)}</td>
            </tr>
        `;

        document.getElementById('result').classList.remove('hidden');
        document.getElementById('errorMsg').classList.add('hidden');
    }

    function showLoading(show) {
        document.getElementById('loading').classList.toggle('hidden', !show);
    }

    function hideResult() {
        document.getElementById('result').classList.add('hidden');
        document.getElementById('errorMsg').classList.add('hidden');
    }

    function showError(msg) {
        const el = document.getElementById('errorMsg');
        el.textContent = '⚠️ ' + msg;
        el.classList.remove('hidden');
        document.getElementById('result').classList.add('hidden');
    }

    function formatNumber(n) {
        return new Intl.NumberFormat('id-ID').format(Math.round(n));
    }
</script>
}
