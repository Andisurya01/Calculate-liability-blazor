@model KontrakResultViewModel
@{
    ViewData["Title"]      = "Hasil Perhitungan";
    ViewData["ActiveMenu"] = "kontrak";
}

<div class="max-w-2xl mx-auto">
    <!-- Header -->
    <div class="flex items-center justify-between mb-6">
        <div>
            <h1 class="text-2xl font-bold text-gray-800">Hasil Perhitungan Kredit</h1>
            <p class="text-gray-500 text-sm mt-1">Data berhasil disimpan ke database</p>
        </div>
        <a href="/Kontrak" class="text-sm text-red-600 hover:text-red-700 flex items-center gap-1">
            ← Hitung Ulang
        </a>
    </div>

    <!-- Ringkasan Card -->
    <div class="bg-white rounded-xl shadow-sm border border-gray-100 p-6 mb-4">
        <h2 class="font-semibold text-gray-700 mb-4 text-sm uppercase tracking-wide">Ringkasan Kredit</h2>
        <div class="grid grid-cols-2 gap-3">
            @{
                void Row(string label, string value, bool highlight = false)
                {
                    <div class="@(highlight ? "col-span-2 bg-red-50 border border-red-100 rounded-lg p-3" : "bg-gray-50 rounded-lg p-3")">
                        <p class="text-xs text-gray-500">@label</p>
                        <p class="font-semibold @(highlight ? "text-red-700 text-lg" : "text-gray-800")">@value</p>
                    </div>
                }
            }

            @{ Row("Nomor Kontrak", Model.Kredit.KontrakNo); }
            @{ Row("Nama Klien", Model.Kredit.ClientName); }
            @{ Row("Harga OTR", $"Rp {Model.Kredit.OTR:N0}"); }
            @{ Row("Down Payment", $"Rp {Model.Kredit.HitungDP():N0}"); }
            @{ Row("Pokok Utang", $"Rp {Model.Kredit.HitungPokok():N0}"); }
            @{ Row("Bunga / Tahun", $"{Model.Kredit.TentukanBunga() * 100}% (flat)"); }
            @{ Row("Angsuran / Bulan", $"Rp {Model.Kredit.HitungAngsuran():N0}", true); }
        </div>
    </div>

    <!-- Tombol Lihat Jadwal -->
    <button onclick="document.getElementById('modalJadwal').classList.remove('hidden')"
            class="w-full py-3 bg-red-600 hover:bg-red-700 text-white font-medium rounded-xl transition-colors flex items-center justify-center gap-2">
        📅 Lihat Jadwal Angsuran (@Model.Jadwal.Count bulan)
    </button>
</div>

<!-- Modal Popup Jadwal Angsuran -->
<div id="modalJadwal" class="hidden fixed inset-0 z-50 flex items-center justify-center p-4">
    <!-- Backdrop -->
    <div class="absolute inset-0 bg-black/50" onclick="document.getElementById('modalJadwal').classList.add('hidden')"></div>

    <!-- Modal Content -->
    <div class="relative bg-white rounded-2xl shadow-2xl w-full max-w-2xl flex flex-col" style="max-height: 80vh;">
        <!-- Modal Header -->
        <div class="flex items-center justify-between px-6 py-4 border-b border-gray-100 shrink-0">
            <div>
                <h3 class="font-bold text-gray-800">Jadwal Angsuran</h3>
                <p class="text-xs text-gray-500">@Model.Kredit.KontrakNo — @Model.Kredit.ClientName</p>
            </div>
            <button onclick="document.getElementById('modalJadwal').classList.add('hidden')"
                    class="text-gray-400 hover:text-gray-600 text-xl font-bold w-8 h-8 flex items-center justify-center rounded-full hover:bg-gray-100">
                ×
            </button>
        </div>

        <!-- Scrollable Table -->
        <div class="overflow-y-auto flex-1">
            <table class="w-full text-sm">
                <thead class="bg-red-600 text-white sticky top-0">
                    <tr>
                        <th class="px-4 py-3 text-left font-medium">No</th>
                        <th class="px-4 py-3 text-right font-medium">Angsuran / Bulan</th>
                        <th class="px-4 py-3 text-center font-medium">Jatuh Tempo</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in Model.Jadwal)
                    {
                        <tr class="border-b border-gray-50 hover:bg-gray-50 transition-colors">
                            <td class="px-4 py-3 text-gray-500 font-medium">@item.AngsuranKe</td>
                            <td class="px-4 py-3 text-right font-semibold text-gray-800">Rp @item.AngsuranPerBulan.ToString("N0")</td>
                            <td class="px-4 py-3 text-center text-gray-600">@item.TanggalJatuhTempo.ToString("dd MMM yyyy")</td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>

        <!-- Modal Footer -->
        <div class="px-6 py-4 border-t border-gray-100 bg-gray-50 rounded-b-2xl shrink-0">
            <div class="flex justify-between items-center">
                <span class="text-sm text-gray-500">Total @Model.Jadwal.Count angsuran</span>
                <span class="font-bold text-gray-800">
                    Total: Rp @Model.Jadwal.Sum(j => j.AngsuranPerBulan).ToString("N0")
                </span>
            </div>
        </div>
    </div>
</div>
