@model KontrakInputViewModel
@{
    ViewData["Title"]      = "Input Kontrak Baru";
    ViewData["ActiveMenu"] = "kontrak";
}

<div class="max-w-2xl mx-auto">
    <!-- Header -->
    <div class="mb-6">
        <h1 class="text-2xl font-bold text-gray-800">Pendaftaran Kontrak Baru</h1>
        <p class="text-gray-500 text-sm mt-1">Lengkapi detail pembiayaan dan informasi klien di bawah ini dengan benar.</p>
    </div>

    <!-- Error -->
    @if (!ViewData.ModelState.IsValid)
    {
        <div class="bg-red-50 border border-red-200 text-red-700 rounded-lg px-4 py-3 mb-6 text-sm">
            @foreach (var error in ViewData.ModelState.Values.SelectMany(v => v.Errors))
            {
                <p>⚠️ @error.ErrorMessage</p>
            }
        </div>
    }

    <!-- Form Card -->
    <div class="bg-white rounded-xl shadow-sm border border-gray-100 p-6">
        <form asp-action="Hitung" asp-controller="Kontrak" method="post">
            @Html.AntiForgeryToken()

            <div class="grid grid-cols-2 gap-4">
                <!-- Nomor Kontrak -->
                <div>
                    <label asp-for="KontrakNo" class="block text-sm font-medium text-gray-700 mb-1"></label>
                    <div class="relative">
                        <span class="absolute left-3 top-2.5 text-gray-400 text-sm">#</span>
                        <input asp-for="KontrakNo" class="w-full pl-7 pr-3 py-2 border border-gray-200 rounded-lg text-sm focus:outline-none focus:ring-2 focus:ring-red-300" />
                    </div>
                    <span asp-validation-for="KontrakNo" class="text-red-500 text-xs"></span>
                </div>

                <!-- Nama Klien -->
                <div>
                    <label asp-for="ClientName" class="block text-sm font-medium text-gray-700 mb-1"></label>
                    <input asp-for="ClientName" placeholder="Masukkan nama lengkap klien"
                           class="w-full px-3 py-2 border border-gray-200 rounded-lg text-sm focus:outline-none focus:ring-2 focus:ring-red-300" />
                    <span asp-validation-for="ClientName" class="text-red-500 text-xs"></span>
                </div>

                <!-- OTR -->
                <div class="col-span-2">
                    <label asp-for="OTR" class="block text-sm font-medium text-gray-700 mb-1"></label>
                    <div class="relative">
                        <span class="absolute left-3 top-2.5 text-gray-400 text-sm">Rp</span>
                        <input asp-for="OTR" type="number" placeholder="0"
                               class="w-full pl-10 pr-3 py-2 border border-gray-200 rounded-lg text-sm focus:outline-none focus:ring-2 focus:ring-red-300" />
                    </div>
                    <span asp-validation-for="OTR" class="text-red-500 text-xs"></span>
                </div>

                <!-- DP -->
                <div>
                    <label asp-for="PersenDP" class="block text-sm font-medium text-gray-700 mb-1"></label>
                    <div class="relative">
                        <input asp-for="PersenDP" type="number" step="0.01"
                               class="w-full pr-8 px-3 py-2 border border-gray-200 rounded-lg text-sm focus:outline-none focus:ring-2 focus:ring-red-300" />
                        <span class="absolute right-3 top-2.5 text-gray-400 text-sm">%</span>
                    </div>
                    <p class="text-xs text-gray-400 mt-1">Persentase dari nilai OTR</p>
                    <span asp-validation-for="PersenDP" class="text-red-500 text-xs"></span>
                </div>

                <!-- Tenor -->
                <div>
                    <label asp-for="Tenor" class="block text-sm font-medium text-gray-700 mb-1"></label>
                    <div class="relative">
                        <input asp-for="Tenor" type="number"
                               class="w-full pr-14 px-3 py-2 border border-gray-200 rounded-lg text-sm focus:outline-none focus:ring-2 focus:ring-red-300" />
                        <span class="absolute right-3 top-2.5 text-gray-400 text-sm">Bulan</span>
                    </div>
                    <p class="text-xs text-gray-400 mt-1">≤12: 12% | 13-24: 14% | >24: 16.5%</p>
                    <span asp-validation-for="Tenor" class="text-red-500 text-xs"></span>
                </div>

                <!-- Tanggal Mulai -->
                <div class="col-span-2">
                    <label asp-for="TanggalMulai" class="block text-sm font-medium text-gray-700 mb-1"></label>
                    <input asp-for="TanggalMulai" type="date"
                           class="w-full px-3 py-2 border border-gray-200 rounded-lg text-sm focus:outline-none focus:ring-2 focus:ring-red-300" />
                    <span asp-validation-for="TanggalMulai" class="text-red-500 text-xs"></span>
                </div>
            </div>

            <!-- Buttons -->
            <div class="flex justify-between items-center mt-6 pt-4 border-t border-gray-100">
                <button type="reset"
                        class="px-4 py-2 text-sm text-gray-600 hover:text-gray-800 transition-colors">
                    Batalkan
                </button>
                <button type="submit"
                        class="px-6 py-2 bg-red-600 hover:bg-red-700 text-white text-sm font-medium rounded-lg transition-colors flex items-center gap-2">
                    Simpan Kontrak
                </button>
            </div>
        </form>
    </div>
</div>
