@page "/denda"
@rendermode InteractiveServer
@using IMSFinance.Models.ViewModels
@using IMSFinance.Services
@inject IKreditService DbService
@inject IKreditJsonService JsonService
@inject ILogger<Denda> Logger

<PageTitle>Cek Denda Keterlambatan</PageTitle>

<div class="max-w-3xl mx-auto">
    <div class="mb-6">
        <h1 class="text-2xl font-bold text-gray-800"> Cek Denda Keterlambatan</h1>
        <p class="text-gray-500 text-sm mt-1">Hitung denda 0,1% per hari dari angsuran yang belum dibayarkan.</p>
    </div>

    <div class="bg-white rounded-xl shadow-sm border border-gray-100 p-6 mb-6">
        <div class="grid grid-cols-3 gap-4 mb-5">
            <div>
                <label class="block text-sm font-medium text-gray-700 mb-1">Nomor Kontrak</label>
                <input @bind="kontrakNo" placeholder="AGR00001"
                       class="w-full px-3 py-2 border border-gray-200 rounded-lg text-sm focus:outline-none focus:ring-2 focus:ring-red-300" />
            </div>
            <div>
                <label class="block text-sm font-medium text-gray-700 mb-1">Per Tanggal</label>
                <input type="date" @bind="perTanggal"
                       class="w-full px-3 py-2 border border-gray-200 rounded-lg text-sm focus:outline-none focus:ring-2 focus:ring-red-300" />
            </div>
            <div>
                <label class="block text-sm font-medium text-gray-700 mb-1">Sudah Bayar s/d Ke-</label>
                <input type="number" @bind="sudahBayarKe" min="0"
                       class="w-full px-3 py-2 border border-gray-200 rounded-lg text-sm focus:outline-none focus:ring-2 focus:ring-red-300" />
            </div>
        </div>

        <div class="flex items-center gap-3 mb-5">
            <span class="text-sm text-gray-600 font-medium">Sumber data:</span>
            <div class="flex bg-gray-100 rounded-lg p-1">
                <button @onclick='() => sumber = "db"'
                        class="@(sumber == "db" ? "bg-red-600 text-white" : "text-gray-500 hover:text-gray-700") px-4 py-1.5 text-sm rounded-md font-medium transition-all">
                    Database
                </button>
                <button @onclick='() => sumber = "json"'
                        class="@(sumber == "json" ? "bg-red-600 text-white" : "text-gray-500 hover:text-gray-700") px-4 py-1.5 text-sm rounded-md font-medium transition-all">
                    JSON
                </button>
            </div>
        </div>

        <button @onclick="CekDenda" disabled="@isLoading"
                class="w-full py-2.5 bg-red-600 hover:bg-red-700 text-white font-medium rounded-lg transition-colors text-sm">
            @(isLoading ? "Menghitung..." : "Hitung Denda")
        </button>
    </div>

    @if (!string.IsNullOrEmpty(errorMessage))
    {
        <div class="bg-red-50 border border-red-200 text-red-700 rounded-lg px-4 py-3 mb-4 text-sm">
            ⚠️ @errorMessage
        </div>
    }

    @if (result != null && result.Count > 0)
    {
        decimal totalDenda = result.Sum(d => d.TotalDenda);
        <div class="bg-red-50 border border-red-200 rounded-xl p-5 mb-4 flex justify-between items-center">
            <div>
                <p class="text-sm text-red-600 font-medium">Total Keseluruhan Denda</p>
                <p class="text-3xl font-bold text-red-700">Rp @totalDenda.ToString(format: "N0")</p>
            </div>
            <div class="text-right">
                <p class="text-sm text-red-500">@result.Count angsuran terlambat</p>
                <p class="text-xs text-red-400 mt-1">Sumber: @(sumber == "db" ? "Database" : "JSON")</p>
            </div>
        </div>

        <div class="bg-white rounded-xl shadow-sm border border-gray-100 overflow-hidden">
            <div class="px-6 py-4 border-b border-gray-100">
                <h3 class="font-semibold text-gray-700 text-sm">Detail Denda Per Angsuran</h3>
            </div>
            <table class="w-full text-sm">
                <thead class="bg-gray-50">
                    <tr>
                        <th class="px-4 py-3 text-left text-xs font-semibold text-gray-500 uppercase">Kontrak No</th>
                        <th class="px-4 py-3 text-left text-xs font-semibold text-gray-500 uppercase">Client</th>
                        <th class="px-4 py-3 text-center text-xs font-semibold text-gray-500 uppercase">Angsuran Ke</th>
                        <th class="px-4 py-3 text-center text-xs font-semibold text-gray-500 uppercase">Hari Terlambat</th>
                        <th class="px-4 py-3 text-right text-xs font-semibold text-gray-500 uppercase">Total Denda</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (DendaItemViewModel d in result)
                    {
                        <tr class="border-b border-gray-50 hover:bg-gray-50">
                            <td class="px-4 py-3 text-gray-700 font-medium">@d.KontrakNo</td>
                            <td class="px-4 py-3 text-gray-600">@d.ClientName</td>
                            <td class="px-4 py-3 text-center">
                                <span class="bg-red-100 text-red-700 text-xs font-semibold px-2 py-1 rounded-full">@d.AngsuranKe</span>
                            </td>
                            <td class="px-4 py-3 text-center">
                                <span class="bg-orange-100 text-orange-700 text-xs font-semibold px-2 py-1 rounded-full">@d.HariKeterlambatan Hari</span>
                            </td>
                            <td class="px-4 py-3 text-right font-semibold text-red-600">Rp @d.TotalDenda.ToString(format: "N0")</td>
                        </tr>
                    }
                </tbody>
                <tfoot class="bg-gray-50 font-bold">
                    <tr>
                        <td colspan="4" class="px-4 py-3 text-right text-sm text-gray-600">Total Denda:</td>
                        <td class="px-4 py-3 text-right text-red-700">Rp @totalDenda.ToString(format: "N0")</td>
                    </tr>
                </tfoot>
            </table>
        </div>
    }
</div>

@code {
    private string kontrakNo    = string.Empty;
    private DateTime perTanggal = DateTime.Today;
    private int sudahBayarKe    = 5;
    private string sumber       = "db";
    private bool isLoading      = false;
    private string errorMessage = string.Empty;
    private List<DendaItemViewModel>? result;

    private async Task CekDenda()
    {
        if (string.IsNullOrWhiteSpace(kontrakNo))
        {
            errorMessage = "Nomor kontrak wajib diisi.";
            return;
        }

        isLoading    = true;
        errorMessage = string.Empty;
        result       = null;

        try
        {
            result = sumber == "json"
                ? await JsonService.GetDendaAsync(kontrakNo, perTanggal, sudahBayarKe)
                : await DbService.GetDendaAsync(kontrakNo, perTanggal, sudahBayarKe);

            if (result.Count == 0)
                errorMessage = $"Tidak ada denda untuk kontrak '{kontrakNo}'.";
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, message: "Error CekDenda");
            errorMessage = "Gagal mengambil data. Periksa koneksi.";
        }
        finally
        {
            isLoading = false;
        }
    }
}
