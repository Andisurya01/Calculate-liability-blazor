@inherits LayoutComponentBase

<div class="flex min-h-screen bg-gray-100">

    <aside class="w-64 min-h-screen bg-white shadow-lg flex flex-col fixed left-0 top-0 z-30">
        <div class="bg-gradient-to-r from-red-700 to-red-500 px-6 py-5">
            <div class="text-white font-bold text-xl tracking-wide">IMS Finance</div>
            <div class="text-red-200 text-xs mt-1">Admin Panel</div>
        </div>

        <nav class="flex-1 px-4 py-6 space-y-1">
            <p class="text-xs font-semibold text-gray-400 uppercase tracking-wider mb-3 px-2">Menu</p>

            <NavLink href="/"         Match="NavLinkMatch.All"
                     class="flex items-center gap-3 px-3 py-2.5 rounded-lg text-sm font-medium transition-all text-gray-600 hover:bg-gray-50"
                     ActiveClass="bg-red-50 text-red-700 border-l-4 border-red-600">
                Input Kontrak Baru
            </NavLink>

            <NavLink href="/jatuh-tempo"
                     class="flex items-center gap-3 px-3 py-2.5 rounded-lg text-sm font-medium transition-all text-gray-600 hover:bg-gray-50"
                     ActiveClass="bg-red-50 text-red-700 border-l-4 border-red-600">
                Cek Jatuh Tempo
            </NavLink>

            <NavLink href="/denda"
                     class="flex items-center gap-3 px-3 py-2.5 rounded-lg text-sm font-medium transition-all text-gray-600 hover:bg-gray-50"
                     ActiveClass="bg-red-50 text-red-700 border-l-4 border-red-600">
                Cek Denda
            </NavLink>
        </nav>

        <div class="px-4 py-4 border-t border-gray-100">
            <p class="text-xs text-gray-400 text-center">© 2024 PT. Inovasi Mitra Sejati</p>
        </div>
    </aside>

    <main class="flex-1 ml-64 p-8">
        @Body
    </main>
</div>